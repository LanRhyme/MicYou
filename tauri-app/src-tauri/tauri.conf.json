{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MicYou",
  "version": "2.0.0",
  "identifier": "com.lanrhyme.micyou",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run sync-version && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MicYou",
        "width": 800,
        "height": 600,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "acrylic",
            "blur"
          ]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
